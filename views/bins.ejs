<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Garbage Bins — Waste Watch</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="wrap header-inner">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true">◉</span>
        <div>
          <h1><a href="/" class="brand-link">Smart Waste Dashboard</a></h1>
          <p class="tagline">🗑️ Monitor bin status across the city</p>
        </div>
      </div>
      <%- include('partials/nav', { citizen: typeof citizen !== 'undefined' ? citizen : null }) %>
    </div>
  </header>
  <br>

  <main class="wrap">
    <div class="stats-container">
      <div class="stat-box">
        <h3 id="totalBins">0</h3>
        <p>Total Bins</p>
      </div>
      <div class="stat-box">
        <h3 id="highBins">0</h3>
        <p>High Priority</p>
      </div>
      <div class="stat-box">
        <h3 id="lowBins">0</h3>
        <p>Low Priority</p>
      </div>
    </div>

    <div id="map" style="
      height:400px;
      margin-bottom:20px;
      border-radius:15px;
      overflow:hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    "></div>

    <section class="panel">
      <div class="bin-section-header">
        <h2>Bin Status</h2>
        <% if (citizen && citizen.role === 'admin') { %>
          <a href="/admin/install-bin" class="btn btn-primary btn-sm">+ Install New Bin</a>
        <% } %>
      </div>
      <div id="bins" class="main-grid"></div>
    </section>
  </main>

  <!-- Pass role to JS -->
  <script>
    var USER_ROLE = '<%= citizen && citizen.role ? citizen.role : "citizen" %>';
  </script>

  <script>
    fetch('/bins')
    .then(res => res.json())
    .then(data => {
      data.sort((a, b) => b.level - a.level);
      let output = "";
      data.forEach(bin => {
        let color = "";
        let label = "";
        if (bin.level > 80) {
          color = "#e74c3c";
          label = "High";
        } else if (bin.level > 50) {
          color = "#f1c40f";
          label = "Medium";
        } else {
          color = "#2ecc71";
          label = "Low";
        }

        let adminActions = '';
        if (USER_ROLE === 'admin') {
          adminActions = `
            <div class="bin-admin-actions">
              <a href="/admin/edit-bin/${bin._id}" class="btn btn-ghost btn-sm">✏️ Edit</a>
              <form action="/admin/delete-bin/${bin._id}" method="post" class="inline-form" onsubmit="return confirm('Delete this bin permanently?');">
                <button type="submit" class="btn btn-danger btn-sm">🗑️ Delete</button>
              </form>
            </div>
          `;
        }

        output += `
          <div class="report-card" style="border-left: 6px solid ${color};">
            <div class="report-body">
              <h3>🗑️ ${bin.location}</h3>
              <p><strong>Fill Level:</strong> ${bin.level}%</p>
              <div style="
                background:#eee;
                border-radius:10px;
                overflow:hidden;
                height:10px;
                margin:10px 0;">
                <div style="
                  width:${bin.level}%;
                  background:${color};
                  height:100%;
                  transition: width 0.5s ease;">
                </div>
              </div>
              <p><strong>Status:</strong>
                <span style="color:${color}; font-weight:bold;">
                  ${label}
                </span>
              </p>
              ${adminActions}
            </div>
          </div>
        `;
      });

      document.getElementById("bins").innerHTML = output;
    });
  </script>

  <script>
    function initMap() {
      const map = new google.maps.Map(document.getElementById("map"), {
        center: { lat: 28.6139, lng: 77.2090 },
        zoom: 12,
      });

      fetch('/bins')
        .then(res => res.json())
        .then(data => {
          let total = data.length;
          let high = 0;
          let low = 0;

          data.forEach(bin => {
            if (bin.level > 80) high++;
            else low++;
          });

          document.getElementById("totalBins").innerText = total;
          document.getElementById("highBins").innerText = high;
          document.getElementById("lowBins").innerText = low;

          data.forEach(bin => {
            let colorName = "green";
            let statusColor = "#2ecc71";

            if (bin.level > 80) {
              colorName = "red";
              statusColor = "#e74c3c";
            } else if (bin.level > 50) {
              colorName = "yellow";
              statusColor = "#f1c40f";
            }

            const marker = new google.maps.Marker({
              position: {
                lat: 28.61 + Math.random()/100,
                lng: 77.20 + Math.random()/100
              },
              map: map,
              title: bin.location,
              icon: {
                url: `http://maps.google.com/mapfiles/ms/icons/${colorName}-dot.png`
              }
            });

            const info = new google.maps.InfoWindow({
              content: `
                <div style="color: #e8f5e9; font-family: system-ui, sans-serif; min-width: 160px; padding: 4px 0;">
                  <h3 style="margin: 0 0 4px 0; color: #a5d6a7; font-size: 15px; font-weight: 700;">
                    🗑️ ${bin.location}
                  </h3>
                  <p style="margin: 4px 0 0 0; color: #e8f5e9; font-size: 13px;">
                    <strong>Fill Level:</strong> <span style="color: ${statusColor}; font-weight: bold;">${bin.level}%</span>
                  </p>
                </div>
              `
            });

            marker.addListener("click", () => {
              info.open(map, marker);
            });
          });
        });
    }
  </script>

  <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDDKEejrX1H5-JVx5HUFobMNKLkvfA2S7I&callback=initMap" async defer></script>

  <footer class="site-footer">
    <div class="wrap">
      <p>Local waste visibility — share responsibly and follow municipal disposal rules.</p>
    </div>
  </footer>
</body>
</html>