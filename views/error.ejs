<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'Error' %> — Waste Watch</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600&family=Fraunces:opsz,wght@9..144,600&display=swap" rel="stylesheet" />
</head>
<body class="auth-body">
  <main class="wrap auth-main">
    <section class="panel auth-panel" aria-labelledby="err-heading">
      <h2 id="err-heading"><%= typeof status !== 'undefined' ? status : 'Error' %></h2>
      <p class="auth-lead"><%= typeof message !== 'undefined' ? message : 'An error occurred.' %></p>
      <p class="auth-switch"><a href="/">Back to home</a></p>
    </section>
  </main>
</body>
</html>
