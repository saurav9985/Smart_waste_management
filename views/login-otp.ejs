<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Login with OTP — Waste Watch</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet" />
</head>
<body class="auth-body">
  <header class="site-header">
    <div class="wrap header-inner">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true">◉</span>
        <div>
          <h1><a href="/" class="brand-link">Waste Watch</a></h1>
          <p class="tagline">Citizen login</p>
        </div>
      </div>
      <%- include('partials/nav', { citizen: null }) %>
    </div>
  </header>

  <main class="wrap auth-main">
    <section class="panel auth-panel" aria-labelledby="login-heading">
      <h2 id="login-heading">Login with OTP</h2>
      <p class="auth-lead">Enter your registered mobile number to receive a one-time password.</p>
      <% if (error) { %>
        <p class="flash flash-error" role="alert"><%= error %></p>
      <% } %>
      <form class="auth-form" action="/login/otp/send" method="post">
        <label class="field">
          <span class="label">Mobile Number</span>
          <input type="tel" name="mobileNumber" autocomplete="tel" pattern="[0-9]*" minlength="10" maxlength="15" required />
        </label>
        <button type="submit" class="btn btn-primary">Send OTP</button>
      </form>
      <p class="auth-switch"><a href="/login">Back to Login with Email</a></p>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <p>Local waste visibility — share responsibly and follow municipal disposal rules.</p>
    </div>
  </footer>
</body>
</html>
